{
  "name": "autocore",
  "private": true,
  "workspaces": [
    "app",
    "apps/portal",
    "apps/api",
    "packages/database",
    "packages/types"
  ],
  "scripts": {
    "predev": "npx --yes kill-port 4000 3000 3001 && node scripts/generate-dev-ssl.mjs",
    "dev": "node scripts/print-lan-url.mjs && concurrently -k -n api,dash,portal -c blue,green,magenta \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:portal\"",
    "dev:portal": "npm run dev -w @autocore/portal",
    "lan:url": "node scripts/print-lan-url.mjs",
    "preview:lan": "node scripts/print-lan-url.mjs && npm run preview -w app -- --host",
    "dev:free": "npx --yes kill-port 4000 3000 3001",
    "dev:web": "npm run dev -w app",
    "dev:dashboard": "npm run dev -w app",
    "dev:api": "npm run dev -w @autocore/api",
    "start": "npm run db:up && npm run dev",
    "build": "npm run build -w @autocore/database && npm run build -w @autocore/api && npm run build -w app && npm run build -w @autocore/portal",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run migrate:dev -w @autocore/database",
    "db:deploy": "npm run migrate:deploy -w @autocore/database",
    "db:seed": "npm run seed -w @autocore/database",
    "db:init": "npm run db:deploy && npm run db:seed",
    "db:studio": "npm run studio -w @autocore/database",
    "db:reset": "npm run migrate:reset -w @autocore/database",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f --tail=200",
    "prod:migrate": "npm run migrate:deploy -w @autocore/database",
    "supabase:up": "docker compose -f docker-compose.supabase.yml up -d --build",
    "supabase:down": "docker compose -f docker-compose.supabase.yml down",
    "supabase:migrate": "npm run migrate:deploy -w @autocore/database",
    "supabase:seed": "npm run seed -w @autocore/database",
    "supabase:init": "npm run supabase:migrate && npm run supabase:seed",
    "env:sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-env.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "selfsigned": "^2.4.1"
  }
}
