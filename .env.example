# =============================================================================
# LOCAL (Docker Compose) — copie para .env na raiz e apps/api/.env
# =============================================================================
DATABASE_URL="postgresql://autocore:autocore@localhost:5432/autocore"
DIRECT_URL="postgresql://autocore:autocore@localhost:5432/autocore"
REDIS_URL="redis://localhost:6379"

# API NestJS
API_PORT=4000
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000,https://localhost:3001"

# Web Push (portal PWA no navegador) — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:oficinadobeto@gmail.com"

# Firebase FCM (push no app Android) — JSON da conta de serviço em uma linha
# Firebase Console → oficinadobeto-portal → Contas de serviço → Gerar nova chave
# Rode: node scripts/setup-firebase-fcm.mjs caminho/service-account.json
FIREBASE_SERVICE_ACCOUNT=""
# Alternativa se a Vercel truncar o JSON:
# FIREBASE_SERVICE_ACCOUNT_BASE64=""

# Dashboard ERP — app/.env (porta 3000)
VITE_API_URL="http://localhost:4000"
VITE_PORTAL_URL="https://oficinadobeto-portal.vercel.app"
VITE_APP_NAME="OFICINA DO BETO"
VITE_APP_TAGLINE="OFICINA MECÂNICA"
VITE_SINGLE_TENANT="true"
VITE_DEFAULT_ORGANIZATION_NAME="OFICINA DO BETO"

# Portal do cliente — apps/portal/.env (porta 3001)
# VITE_API_URL=
# VITE_DASHBOARD_URL="http://localhost:3000"

# Instância dedicada (uma empresa por deploy)
SINGLE_TENANT="true"
DEFAULT_ORGANIZATION_NAME="OFICINA DO BETO"

# =============================================================================
# SUPABASE (produção) — ao subir para nuvem
# =============================================================================
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# SUPABASE_URL="https://[ref].supabase.co"
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
# VITE_SUPABASE_URL=""
# VITE_SUPABASE_ANON_KEY=""
