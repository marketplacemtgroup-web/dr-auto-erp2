# =============================================================================
# SUPABASE — Oficina Scalibur (dr-auto-erp2)
# Copie para .env (raiz), packages/database/.env e apps/api/.env
# Projeto: https://zejpaxphyaufrwdholyx.supabase.co
# =============================================================================

# Settings → Database → Connection string → Transaction pooler (porta 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Settings → Database → Connection string → Direct (porta 5432) — só migrations
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Settings → API
SUPABASE_URL="https://zejpaxphyaufrwdholyx.supabase.co"
SUPABASE_ANON_KEY="sua-anon-key"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# Storage (obrigatório na Vercel — upload de fotos)
# Buckets: os-media, vehicle-photos, documents (ver scripts/supabase-storage-buckets.sql)

# API NestJS (produção) — Oficina Scalibur (instância dedicada)
API_PORT=4000
JWT_SECRET="gere-uma-string-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="https://dr-auto-erp2-app.vercel.app,https://dr-auto-erp2-portal.vercel.app"
REDIS_URL="redis://redis:6379"
SINGLE_TENANT="true"
DEFAULT_ORGANIZATION_NAME="Oficina Scalibur"

VITE_APP_NAME="Oficina Scalibur"
VITE_APP_TAGLINE="OFICINA MECÂNICA"
VITE_SINGLE_TENANT="true"
VITE_DEFAULT_ORGANIZATION_NAME="Oficina Scalibur"
VITE_API_URL="https://dr-auto-erp2-api.vercel.app"
VITE_PORTAL_URL="https://dr-auto-erp2-portal.vercel.app"
VITE_DASHBOARD_URL="https://dr-auto-erp2-app.vercel.app"

# Opcional (quando migrar auth/storage no frontend)
# VITE_SUPABASE_URL="https://zejpaxphyaufrwdholyx.supabase.co"
# VITE_SUPABASE_ANON_KEY="sua-anon-key"
