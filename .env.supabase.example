# =============================================================================
# SUPABASE — copie para .env (raiz), packages/database/.env e apps/api/.env
# Substitua [ref], [password] e [region] pelos valores do painel Supabase.
# =============================================================================

# Settings → Database → Connection string → Transaction pooler (porta 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Settings → Database → Connection string → Direct (porta 5432) — só migrations
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Settings → API
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_ANON_KEY="sua-anon-key"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# API NestJS (produção) — Scalibur Oficinas (instância dedicada)
API_PORT=4000
JWT_SECRET="gere-uma-string-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="https://seu-dominio.com.br"
REDIS_URL="redis://redis:6379"
SINGLE_TENANT="true"
DEFAULT_ORGANIZATION_NAME="Scalibur Oficinas"

VITE_APP_NAME="Scalibur"
VITE_APP_TAGLINE="Oficinas"
VITE_SINGLE_TENANT="true"
VITE_DEFAULT_ORGANIZATION_NAME="Scalibur Oficinas"

# Frontend — em produção atrás do nginx use caminho relativo ou URL pública da API
VITE_API_URL=""

# Opcional (quando migrar auth/storage no frontend)
# VITE_SUPABASE_URL="https://[ref].supabase.co"
# VITE_SUPABASE_ANON_KEY="sua-anon-key"
