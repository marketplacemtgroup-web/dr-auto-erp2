# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# PORTAL_API_URL: Backend NestJS (mesma API do ERP e do portal web).
# Deve incluir /api/ no final.
# Produção (Vercel): https://oficina-beto-api.vercel.app/api/
# Dev local:         http://10.0.2.2:4000/api/  (emulador → localhost:4000)
PORTAL_API_URL=https://oficina-beto-api.vercel.app/api/

# PORTAL_DEEP_LINK_HOST: domínio do SITE do portal (PWA), NÃO da API.
# Usado para abrir o app ao tocar links enviados pela oficina no WhatsApp.
# Sem domínio customizado, use a URL da Vercel do portal (só o host, sem https://):
#   https://oficina-beto-portal.vercel.app/acesso/TOKEN  → host abaixo
PORTAL_DEEP_LINK_HOST=oficina-beto-portal.vercel.app
