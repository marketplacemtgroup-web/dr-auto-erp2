generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ServiceOrderStatus {
  RECEIVED
  DIAGNOSIS
  AWAITING_QUOTE
  AWAITING_APPROVAL
  APPROVED
  IN_PROGRESS
  AWAITING_PART
  PAUSED
  AWAITING_PAYMENT
  FINISHED
  DELIVERED
  CANCELLED
}

enum ServiceOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ChecklistResult {
  OK
  ATTENTION
  DAMAGED
  NA
}

enum AttachmentEntityType {
  SERVICE_ORDER
  VEHICLE
  CUSTOMER
}

enum QuoteLineType {
  SERVICE
  PART
  THIRD_PARTY
}

enum CustomerType {
  PF
  PJ
}

enum VehicleKind {
  CAR
  MOTORCYCLE
  TRUCK
  OTHER
}

enum QuoteStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum FinancialEntryType {
  PAYABLE
  RECEIVABLE
}

enum FinancialEntryStatus {
  OPEN
  PAID
  CANCELLED
}

enum StockMovementType {
  IN
  OUT_OS
  RESERVE
  RELEASE
  ADJUST
  RETURN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  BOLETO
  TRANSFER
  OTHER
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  SUPPLY
  WITHDRAWAL
  PAYMENT_IN
  PAYMENT_OUT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum EmploymentType {
  CLT
  AUTONOMO
  MEI
  TERCEIRIZADO
  DIARISTA
  COMISSIONADO
  OUTRO
}

enum EmployeePaymentType {
  FIXO
  FIXO_MAIS_COMISSAO
  SOMENTE_COMISSAO
  DIARIA
  POR_SERVICO
  TERCEIRIZADO
}

enum PaymentPeriodicity {
  MENSAL
  QUINZENAL
  SEMANAL
}

enum CommissionRuleType {
  PERCENTUAL
  VALOR_FIXO
  META
  MANUAL
}

enum CommissionBase {
  MAO_DE_OBRA
  PECAS
  TOTAL_OS
  SERVICO_ESPECIFICO
  PRODUTO_ESPECIFICO
  VENDA_BALCAO
  OS_FINALIZADA
}

enum CommissionTrigger {
  ORCAMENTO_APROVADO
  SERVICO_FINALIZADO
  OS_FINALIZADA
  OS_ENTREGUE
  PAGAMENTO_RECEBIDO
}

enum GeneratedCommissionStatus {
  PENDENTE
  APROVADA
  PAGA
  CANCELADA
  ESTORNADA
}

enum CommissionItemType {
  SERVICO
  PECA
  OS
  MANUAL
}

enum EmployeeEntryType {
  VALE
  ADIANTAMENTO
  BONUS
  DESCONTO
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  DIARIA
  AJUDA_CUSTO
}

enum EmployeeEntryStatus {
  PENDENTE
  APLICADO
  CANCELADO
  PAGO
}

enum PayrollStatus {
  ABERTA
  FECHADA
  PAGA
  CANCELADA
}

enum PayrollItemType {
  SALARIO
  COMISSAO
  BONUS
  VALE
  ADIANTAMENTO
  DESCONTO
  AJUSTE
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  tradeName String?  @map("trade_name")
  document  String?  // CNPJ
  email             String?
  loginEmailDomain  String?  @map("login_email_domain")
  phone             String?
  plan      String   @default("professional")
  logoUrl           String?  @map("logo_url")
  primaryColor      String   @default("#0E7490") @map("primary_color")
  accentColor       String   @default("#0F3D4C") @map("accent_color")
  footerText        String?  @map("footer_text")
  termsServiceOrder String?  @map("terms_service_order") @db.Text
  termsQuote        String?  @map("terms_quote") @db.Text
  portalWelcome     String?  @map("portal_welcome")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches Branch[]
  members  OrganizationMember[]
  roles    Role[]
  customers Customer[]
  vehicles  Vehicle[]
  serviceOrders ServiceOrder[]
  quotes    Quote[]
  products      Product[]
  serviceOrderItems ServiceOrderItem[]
  statusHistory   ServiceOrderStatusHistory[]
  checklistItems  ServiceOrderChecklistItem[]
  attachments     Attachment[]
  quoteLines      QuoteLine[]
  quoteTokens     QuoteAccessToken[]
  customerContacts CustomerContact[]
  auditLogs     AuditLog[]
  dailyRevenues DailyRevenue[]
  purchaseOrders PurchaseOrder[]
  financialEntries FinancialEntry[]
  financialPaymentSplits FinancialPaymentSplit[]
  serviceCatalog ServiceCatalog[]
  stockMovements StockMovement[]
  appointments Appointment[]
  cashSessions CashRegisterSession[]
  cashMovements CashRegisterMovement[]
  portalAccessTokens PortalAccessToken[]
  pushSubscriptions PushSubscription[]
  portalNotifications PortalNotification[]
  fcmTokens FcmToken[]
  officeNotifications OfficeNotification[]
  jobTitles JobTitle[]
  employees Employee[]
  employeePaymentConfigs EmployeePaymentConfig[]
  commissionRules EmployeeCommissionRule[]
  generatedCommissions GeneratedCommission[]
  employeeEntries EmployeeEntry[]
  payrolls Payroll[]
  teamActionLogs TeamActionLog[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  code           String?
  address        String?
  street         String?
  addressNumber  String?  @map("address_number")
  complement     String?
  district       String?
  city           String?
  state          String?
  zipCode        String?  @map("zip_code")
  isMain         Boolean  @default(false) @map("is_main")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]
  serviceOrders ServiceOrder[]

  @@index([organizationId])
  @@map("branches")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile Profile?
  members OrganizationMember[]
  auditLogs AuditLog[]
  statusChanges ServiceOrderStatusHistory[]
  uploadedAttachments Attachment[]
  openedCashSessions CashRegisterSession[] @relation("CashOpenedBy")
  closedCashSessions CashRegisterSession[] @relation("CashClosedBy")

  @@map("users")
}

model Profile {
  id        String   @id
  userId    String   @unique @map("user_id")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  roleId         String   @map("role_id")
  branchId       String?  @map("branch_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  consultantOrders ServiceOrder[] @relation("ConsultantOrders")
  mechanicOrders   ServiceOrder[] @relation("MechanicOrders")
  appointments     Appointment[]
  employee         Employee?

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  slug           String
  name           String
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]
  permissions  RolePermission[]

  @@unique([organizationId, slug])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  action         String
  resource       String?
  metadata       Json?
  ipAddress      String?  @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  customerType   CustomerType @default(PF) @map("customer_type")
  name           String
  document       String?
  phone          String?
  whatsapp       String?
  email          String?
  notes          String?
  street         String?
  addressNumber  String?      @map("address_number")
  complement     String?
  district       String?
  city           String?
  state          String?
  zipCode        String?      @map("zip_code")
  origin         String?
  isActive       Boolean      @default(true) @map("is_active")
  isVip          Boolean      @default(false) @map("is_vip")
  isBlocked      Boolean      @default(false) @map("is_blocked")
  isDelinquent   Boolean      @default(false) @map("is_delinquent")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]
  contacts     CustomerContact[]
  financialEntries FinancialEntry[]
  portalNotifications PortalNotification[]

  @@index([organizationId])
  @@index([organizationId, name])
  @@map("customers")
}

model CustomerContact {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  customerId     String   @map("customer_id")
  name           String
  role           String?
  phone          String?
  email          String?
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_contacts")
}

model Vehicle {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  customerId     String       @map("customer_id")
  plate          String
  brand          String?
  model          String?
  year           Int?
  color          String?
  vehicleKind    VehicleKind  @default(CAR) @map("vehicle_kind")
  chassis        String?
  renavam        String?
  fuelType       String?      @map("fuel_type")
  currentKm      Int?         @map("current_km")
  notes          String?
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceOrders ServiceOrder[]
  appointments  Appointment[]
  portalAccessTokens PortalAccessToken[]
  pushSubscriptions PushSubscription[]
  portalNotifications PortalNotification[]
  fcmTokens FcmToken[]

  @@unique([organizationId, plate])
  @@index([organizationId])
  @@map("vehicles")
}

model ServiceOrder {
  id                   String               @id @default(cuid())
  organizationId       String               @map("organization_id")
  branchId             String?              @map("branch_id")
  vehicleId            String               @map("vehicle_id")
  consultantMemberId   String?              @map("consultant_member_id")
  mechanicMemberId     String?              @map("mechanic_member_id")
  generalResponsibleId String?              @map("general_responsible_id")
  checklistById        String?              @map("checklist_by_id")
  diagnosisById        String?              @map("diagnosis_by_id")
  quoteById            String?              @map("quote_by_id")
  executionById        String?              @map("execution_by_id")
  finalizedById        String?              @map("finalized_by_id")
  number               Int
  status               ServiceOrderStatus   @default(RECEIVED)
  priority             ServiceOrderPriority @default(NORMAL)
  serviceType          String?              @map("service_type")
  entryChannel         String?              @map("entry_channel")
  bay                  String?
  entryKm              Int?                 @map("entry_km")
  enteredAt            DateTime?            @map("entered_at")
  complaint            String?
  diagnosis            String?
  internalNotes        String?              @map("internal_notes")
  customerVisibleNotes String?              @map("customer_visible_notes")
  paymentAgreement     String?              @map("payment_agreement")
  estimatedAt          DateTime?            @map("estimated_at")
  totalAmount          Decimal              @default(0) @map("total_amount") @db.Decimal(12, 2)
  deletedAt            DateTime?            @map("deleted_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  consultant   OrganizationMember? @relation("ConsultantOrders", fields: [consultantMemberId], references: [id], onDelete: SetNull)
  mechanic     OrganizationMember? @relation("MechanicOrders", fields: [mechanicMemberId], references: [id], onDelete: SetNull)
  generalResponsible Employee? @relation("OsGeneralResponsible", fields: [generalResponsibleId], references: [id], onDelete: SetNull)
  checklistBy        Employee? @relation("OsChecklistBy", fields: [checklistById], references: [id], onDelete: SetNull)
  diagnosisBy        Employee? @relation("OsDiagnosisBy", fields: [diagnosisById], references: [id], onDelete: SetNull)
  quoteBy            Employee? @relation("OsQuoteBy", fields: [quoteById], references: [id], onDelete: SetNull)
  executionBy        Employee? @relation("OsExecutionBy", fields: [executionById], references: [id], onDelete: SetNull)
  finalizedBy        Employee? @relation("OsFinalizedBy", fields: [finalizedById], references: [id], onDelete: SetNull)
  quotes       Quote[]
  generatedCommissions GeneratedCommission[]
  items        ServiceOrderItem[]
  statusHistory ServiceOrderStatusHistory[]
  checklistItems ServiceOrderChecklistItem[]
  attachments  Attachment[]
  stockMovements StockMovement[]
  appointment  Appointment?
  financialEntries FinancialEntry[]
  portalAccessTokens PortalAccessToken[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@map("service_orders")
}

model ServiceOrderStatusHistory {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  serviceOrderId String              @map("service_order_id")
  fromStatus     ServiceOrderStatus? @map("from_status")
  toStatus       ServiceOrderStatus  @map("to_status")
  userId         String?             @map("user_id")
  reason         String?
  notes          String?
  createdAt      DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceOrderId])
  @@map("service_order_status_history")
}

model ServiceOrderChecklistItem {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  serviceOrderId String           @map("service_order_id")
  category       String
  label          String
  sortOrder      Int              @default(0) @map("sort_order")
  result         ChecklistResult?
  notes          String?
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_checklist_items")
}

model Attachment {
  id                String               @id @default(cuid())
  organizationId    String               @map("organization_id")
  entityType        AttachmentEntityType @map("entity_type")
  entityId          String               @map("entity_id")
  serviceOrderId    String?              @map("service_order_id")
  category          String               @default("general")
  fileName          String               @map("file_name")
  mimeType          String               @map("mime_type")
  storagePath       String               @map("storage_path")
  visibleToCustomer Boolean              @default(false) @map("visible_to_customer")
  showOnQuote       Boolean              @default(false) @map("show_on_quote")
  uploadedByUserId String?             @map("uploaded_by_user_id")
  createdAt         DateTime             @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  uploadedBy   User?         @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId])
  @@index([serviceOrderId])
  @@map("attachments")
}

enum ServiceOrderItemType {
  SERVICE
  PART
}

model ServiceOrderItem {
  id             String               @id @default(cuid())
  organizationId String               @map("organization_id")
  serviceOrderId String               @map("service_order_id")
  productId      String?              @map("product_id")
  catalogItemId  String?              @map("catalog_item_id")
  description    String
  itemType       ServiceOrderItemType @default(SERVICE) @map("item_type")
  quantity           Int                  @default(1)
  unitPrice          Decimal              @default(0) @map("unit_price") @db.Decimal(12, 2)
  discount           Decimal              @default(0) @db.Decimal(12, 2)
  executorId         String?              @map("executor_id")
  soldById           String?              @map("sold_by_id")
  appliedById        String?              @map("applied_by_id")
  separatedById      String?              @map("separated_by_id")
  expectedCommission Decimal?             @map("expected_commission") @db.Decimal(12, 2)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  catalogItem  ServiceCatalog? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  executor     Employee?    @relation("ItemExecutor", fields: [executorId], references: [id], onDelete: SetNull)
  soldBy       Employee?    @relation("ItemSoldBy", fields: [soldById], references: [id], onDelete: SetNull)
  appliedBy    Employee?    @relation("ItemAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)
  separatedBy  Employee?    @relation("ItemSeparatedBy", fields: [separatedById], references: [id], onDelete: SetNull)
  generatedCommissions GeneratedCommission[]

  @@index([serviceOrderId])
  @@index([executorId])
  @@map("service_order_items")
}

model Quote {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  serviceOrderId String      @map("service_order_id")
  number         Int?
  status         QuoteStatus @default(PENDING)
  amount         Decimal     @db.Decimal(12, 2)
  validUntil     DateTime?   @map("valid_until") @db.Date
  terms          String?
  paymentAgreement String?  @map("payment_agreement")
  customerComment String?    @map("customer_comment")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  lines        QuoteLine[]
  accessTokens QuoteAccessToken[]
  financialEntries FinancialEntry[]
  generatedCommissions GeneratedCommission[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@map("quotes")
}

model QuoteLine {
  id                String        @id @default(cuid())
  organizationId    String        @map("organization_id")
  quoteId           String        @map("quote_id")
  lineType          QuoteLineType @default(SERVICE) @map("line_type")
  description       String
  quantity          Int           @default(1)
  unitPrice         Decimal       @default(0) @map("unit_price") @db.Decimal(12, 2)
  discount          Decimal       @default(0) @db.Decimal(12, 2)
  approved          Boolean?
  sortOrder         Int           @default(0) @map("sort_order")
  serviceOrderItemId String?      @map("service_order_item_id")
  createdAt         DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_lines")
}

model QuoteAccessToken {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  quoteId        String   @map("quote_id")
  token          String   @unique
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  viewLogs     QuoteViewLog[]

  @@index([quoteId])
  @@map("quote_access_tokens")
}

model QuoteViewLog {
  id        String   @id @default(cuid())
  tokenId   String   @map("token_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")
  ipAddress String?  @map("ip_address")

  token QuoteAccessToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId])
  @@map("quote_view_logs")
}

model PortalAccessToken {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  vehicleId      String   @map("vehicle_id")
  serviceOrderId String?  @map("service_order_id")
  token          String   @unique
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([vehicleId])
  @@map("portal_access_tokens")
}

model PushSubscription {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  vehicleId      String   @map("vehicle_id")
  endpoint       String   @unique
  p256dh         String
  auth           String
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("push_subscriptions")
}

model PortalNotification {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  customerId     String    @map("customer_id")
  vehicleId      String    @map("vehicle_id")
  serviceOrderId String?   @map("service_order_id")
  quoteId        String?   @map("quote_id")
  type           String
  title          String
  body           String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, readAt, createdAt])
  @@map("portal_notifications")
}

model FcmToken {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  vehicleId      String   @map("vehicle_id")
  token          String   @unique
  platform       String   @default("android")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("fcm_tokens")
}

model OfficeNotification {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  type           String
  title          String
  message        String
  metadata       Json?
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, readAt, createdAt])
  @@map("office_notifications")
}

model ServiceCatalog {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  name             String
  category         String?
  estimatedMinutes Int?     @map("estimated_minutes")
  defaultPrice     Decimal  @default(0) @map("default_price") @db.Decimal(12, 2)
  warrantyDays     Int?     @map("warranty_days")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderItems   ServiceOrderItem[]
  commissionRules EmployeeCommissionRule[]

  @@index([organizationId, isActive])
  @@map("service_catalog")
}

model Product {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  sku            String?
  category       String?
  brand          String?
  ncm            String?
  location       String?
  stock          Int      @default(0)
  reservedStock  Int      @default(0) @map("reserved_stock")
  minStock       Int      @default(0) @map("min_stock")
  costPrice      Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  salePrice      Decimal  @default(0) @map("sale_price") @db.Decimal(12, 2)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderItems   ServiceOrderItem[]
  movements    StockMovement[]
  commissionRules EmployeeCommissionRule[]

  @@index([organizationId])
  @@map("products")
}

model StockMovement {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  productId      String            @map("product_id")
  movementType   StockMovementType @map("movement_type")
  quantity       Int
  balanceAfter   Int               @map("balance_after")
  reason         String?
  serviceOrderId String?           @map("service_order_id")
  createdAt      DateTime          @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)

  @@index([organizationId, productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Appointment {
  id               String            @id @default(cuid())
  organizationId   String            @map("organization_id")
  vehicleId        String            @map("vehicle_id")
  mechanicMemberId String?           @map("mechanic_member_id")
  scheduledAt      DateTime          @map("scheduled_at")
  durationMinutes  Int               @default(60) @map("duration_minutes")
  status           AppointmentStatus @default(SCHEDULED)
  bay              String?
  notes            String?
  serviceOrderId   String?           @unique @map("service_order_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  mechanic     OrganizationMember? @relation(fields: [mechanicMemberId], references: [id], onDelete: SetNull)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)

  @@index([organizationId, scheduledAt])
  @@index([vehicleId])
  @@map("appointments")
}

model DailyRevenue {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  date           DateTime @db.Date
  amount         Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@map("daily_revenues")
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  number         String
  supplierName   String              @map("supplier_name")
  status         PurchaseOrderStatus @default(ORDERED)
  totalAmount    Decimal             @default(0) @map("total_amount") @db.Decimal(12, 2)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@map("purchase_orders")
}

model FinancialEntry {
  id                String               @id @default(cuid())
  organizationId    String               @map("organization_id")
  customerId        String?              @map("customer_id")
  serviceOrderId    String?              @map("service_order_id")
  quoteId           String?              @map("quote_id")
  parentEntryId     String?              @map("parent_entry_id")
  description       String
  type              FinancialEntryType
  status            FinancialEntryStatus @default(OPEN)
  paymentMethod     PaymentMethod?       @map("payment_method")
  dueDate           DateTime             @map("due_date") @db.Date
  paidAt            DateTime?            @map("paid_at")
  amount            Decimal              @db.Decimal(12, 2)
  discountAmount    Decimal              @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountPercent   Decimal?             @map("discount_percent") @db.Decimal(5, 2)
  amountReceived    Decimal?             @map("amount_received") @db.Decimal(12, 2)
  installmentNumber Int                  @default(1) @map("installment_number")
  installmentTotal  Int                  @default(1) @map("installment_total")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  quote        Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  parentEntry  FinancialEntry? @relation("Installments", fields: [parentEntryId], references: [id], onDelete: Cascade)
  installments FinancialEntry[] @relation("Installments")
  paymentSplits FinancialPaymentSplit[]
  cashMovements CashRegisterMovement[]

  @@index([organizationId, dueDate])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([serviceOrderId])
  @@map("financial_entries")
}

model FinancialPaymentSplit {
  id               String        @id @default(cuid())
  organizationId   String        @map("organization_id")
  financialEntryId String        @map("financial_entry_id")
  paymentMethod    PaymentMethod @map("payment_method")
  amount           Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now()) @map("created_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  financialEntry FinancialEntry @relation(fields: [financialEntryId], references: [id], onDelete: Cascade)

  @@index([financialEntryId])
  @@map("financial_payment_splits")
}

model CashRegisterSession {
  id              String            @id @default(cuid())
  organizationId  String            @map("organization_id")
  openedByUserId  String            @map("opened_by_user_id")
  closedByUserId  String?           @map("closed_by_user_id")
  status          CashSessionStatus @default(OPEN)
  openingBalance  Decimal           @default(0) @map("opening_balance") @db.Decimal(12, 2)
  closingBalance  Decimal?          @map("closing_balance") @db.Decimal(12, 2)
  expectedBalance Decimal?          @map("expected_balance") @db.Decimal(12, 2)
  openedAt        DateTime          @default(now()) @map("opened_at")
  closedAt        DateTime?         @map("closed_at")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  openedBy     User         @relation("CashOpenedBy", fields: [openedByUserId], references: [id])
  closedBy     User?        @relation("CashClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  movements    CashRegisterMovement[]

  @@index([organizationId, status])
  @@map("cash_register_sessions")
}

model CashRegisterMovement {
  id               String           @id @default(cuid())
  organizationId   String           @map("organization_id")
  sessionId        String           @map("session_id")
  financialEntryId String?          @map("financial_entry_id")
  movementType     CashMovementType @map("movement_type")
  amount           Decimal          @db.Decimal(12, 2)
  description      String?
  createdAt        DateTime         @default(now()) @map("created_at")

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session        CashRegisterSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  financialEntry FinancialEntry?     @relation(fields: [financialEntryId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@map("cash_register_movements")
}

model JobTitle {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  isTechnical    Boolean  @default(false) @map("is_technical")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("job_titles")
}

model Employee {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  memberId       String?        @unique @map("member_id")
  jobTitleId     String?        @map("job_title_id")
  name           String
  cpf            String?
  rg             String?
  phone          String?
  whatsapp       String?
  email          String?
  birthDate      DateTime?      @map("birth_date") @db.Date
  address        String?
  employmentType EmploymentType @default(CLT) @map("employment_type")
  hireDate       DateTime?      @map("hire_date") @db.Date
  terminationDate DateTime?     @map("termination_date") @db.Date
  status         EmployeeStatus @default(ACTIVE)
  photoUrl       String?        @map("photo_url")
  accessProfile  String?        @map("access_profile")
  isTechnical    Boolean        @default(false) @map("is_technical")
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member       OrganizationMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  jobTitle     JobTitle?    @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  paymentConfig EmployeePaymentConfig?
  commissionRules EmployeeCommissionRule[]
  generatedCommissions GeneratedCommission[]
  entries      EmployeeEntry[]
  payrolls     Payroll[]
  documents    EmployeeDocument[]
  actionLogs   TeamActionLog[]

  osGeneralResponsible ServiceOrder[] @relation("OsGeneralResponsible")
  osChecklistBy        ServiceOrder[] @relation("OsChecklistBy")
  osDiagnosisBy        ServiceOrder[] @relation("OsDiagnosisBy")
  osQuoteBy            ServiceOrder[] @relation("OsQuoteBy")
  osExecutionBy        ServiceOrder[] @relation("OsExecutionBy")
  osFinalizedBy        ServiceOrder[] @relation("OsFinalizedBy")
  executedItems        ServiceOrderItem[] @relation("ItemExecutor")
  soldItems            ServiceOrderItem[] @relation("ItemSoldBy")
  appliedItems         ServiceOrderItem[] @relation("ItemAppliedBy")
  separatedItems       ServiceOrderItem[] @relation("ItemSeparatedBy")

  @@index([organizationId, status])
  @@index([organizationId, name])
  @@map("employees")
}

model EmployeePaymentConfig {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  employeeId     String              @unique @map("employee_id")
  paymentType    EmployeePaymentType @map("payment_type")
  fixedSalary    Decimal?            @map("fixed_salary") @db.Decimal(12, 2)
  paymentDay     Int?                @map("payment_day")
  periodicity    PaymentPeriodicity? @default(MENSAL)
  paymentMethod  PaymentMethod?      @map("payment_method")
  bankName       String?             @map("bank_name")
  pixKey         String?             @map("pix_key")
  allowBonus     Boolean             @default(true) @map("allow_bonus")
  allowDiscount  Boolean             @default(true) @map("allow_discount")
  allowAdvance   Boolean             @default(true) @map("allow_advance")
  notes          String?
  isActive       Boolean             @default(true) @map("is_active")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("employee_payment_configs")
}

model EmployeeCommissionRule {
  id                    String              @id @default(cuid())
  organizationId        String              @map("organization_id")
  employeeId            String              @map("employee_id")
  ruleType              CommissionRuleType  @map("rule_type")
  baseCalculation       CommissionBase      @map("base_calculation")
  percentage            Decimal?            @db.Decimal(5, 2)
  fixedAmount           Decimal?            @map("fixed_amount") @db.Decimal(12, 2)
  catalogItemId         String?             @map("catalog_item_id")
  productId             String?             @map("product_id")
  trigger               CommissionTrigger   @default(OS_FINALIZADA)
  considerDiscount      Boolean             @default(true) @map("consider_discount")
  considerOnlyReceived  Boolean             @default(false) @map("consider_only_received")
  isActive              Boolean             @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  catalogItem  ServiceCatalog? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([organizationId, employeeId])
  @@index([employeeId, isActive])
  @@map("employee_commission_rules")
}

model GeneratedCommission {
  id             String                    @id @default(cuid())
  organizationId String                    @map("organization_id")
  employeeId     String                    @map("employee_id")
  serviceOrderId String?                   @map("service_order_id")
  quoteId        String?                   @map("quote_id")
  itemId         String?                   @map("item_id")
  itemType       CommissionItemType        @map("item_type")
  ruleType       CommissionRuleType?         @map("rule_type")
  description    String
  baseAmount     Decimal                   @map("base_amount") @db.Decimal(12, 2)
  percentage     Decimal?                  @db.Decimal(5, 2)
  fixedAmount    Decimal?                  @map("fixed_amount") @db.Decimal(12, 2)
  commissionAmount Decimal                 @map("commission_amount") @db.Decimal(12, 2)
  status         GeneratedCommissionStatus @default(PENDENTE)
  generatedAt    DateTime                  @default(now()) @map("generated_at")
  approvedAt     DateTime?                 @map("approved_at")
  paidAt         DateTime?                 @map("paid_at")
  payrollId      String?                   @map("payroll_id")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  quote        Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  serviceOrderItem ServiceOrderItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  payroll      Payroll?     @relation(fields: [payrollId], references: [id], onDelete: SetNull)

  @@index([organizationId, employeeId, status])
  @@index([serviceOrderId])
  @@map("generated_commissions")
}

model EmployeeEntry {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  employeeId     String              @map("employee_id")
  entryType      EmployeeEntryType   @map("entry_type")
  description    String
  amount         Decimal             @db.Decimal(12, 2)
  entryDate      DateTime            @map("entry_date") @db.Date
  competence     DateTime?           @db.Date
  status         EmployeeEntryStatus @default(PENDENTE)
  paymentMethod  PaymentMethod?      @map("payment_method")
  attachmentUrl  String?             @map("attachment_url")
  notes          String?
  createdByUserId String?            @map("created_by_user_id")
  payrollId      String?             @map("payroll_id")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payroll      Payroll?     @relation(fields: [payrollId], references: [id], onDelete: SetNull)

  @@index([organizationId, employeeId])
  @@index([entryDate])
  @@map("employee_entries")
}

model Payroll {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  employeeId     String        @map("employee_id")
  periodStart    DateTime      @map("period_start") @db.Date
  periodEnd      DateTime      @map("period_end") @db.Date
  fixedSalary    Decimal       @default(0) @map("fixed_salary") @db.Decimal(12, 2)
  totalCommissions Decimal     @default(0) @map("total_commissions") @db.Decimal(12, 2)
  totalBonus     Decimal       @default(0) @map("total_bonus") @db.Decimal(12, 2)
  totalDiscounts Decimal       @default(0) @map("total_discounts") @db.Decimal(12, 2)
  totalAdvances  Decimal       @default(0) @map("total_advances") @db.Decimal(12, 2)
  netTotal       Decimal       @default(0) @map("net_total") @db.Decimal(12, 2)
  status         PayrollStatus @default(ABERTA)
  paidAt         DateTime?     @map("paid_at")
  paymentMethod  PaymentMethod? @map("payment_method")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items        PayrollItem[]
  commissions  GeneratedCommission[]
  entries      EmployeeEntry[]

  @@index([organizationId, periodStart, periodEnd])
  @@index([employeeId, status])
  @@map("payrolls")
}

model PayrollItem {
  id          String          @id @default(cuid())
  payrollId   String          @map("payroll_id")
  itemType    PayrollItemType @map("item_type")
  description String
  amount      Decimal         @db.Decimal(12, 2)
  referenceId String?         @map("reference_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
  @@map("payroll_items")
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  docType    String   @map("doc_type")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_documents")
}

model TeamActionLog {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  employeeId     String?  @map("employee_id")
  module         String
  action         String
  entity         String?
  entityId       String?  @map("entity_id")
  description    String
  ipAddress      String?  @map("ip_address")
  device         String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([employeeId])
  @@map("team_action_logs")
}
