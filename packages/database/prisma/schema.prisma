generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ServiceOrderStatus {
  RECEIVED
  DIAGNOSIS
  AWAITING_QUOTE
  AWAITING_APPROVAL
  APPROVED
  IN_PROGRESS
  AWAITING_PART
  PAUSED
  AWAITING_PAYMENT
  FINISHED
  DELIVERED
  CANCELLED
}

enum ServiceOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ChecklistResult {
  OK
  ATTENTION
  DAMAGED
  NA
}

enum AttachmentEntityType {
  SERVICE_ORDER
  VEHICLE
  CUSTOMER
}

enum QuoteLineType {
  SERVICE
  PART
  THIRD_PARTY
}

enum CustomerType {
  PF
  PJ
}

enum VehicleKind {
  CAR
  MOTORCYCLE
  TRUCK
  OTHER
}

enum QuoteStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  ORDER_SENT
  AWAITING_RECEIPT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchaseFinancialStatus {
  NOT_GENERATED
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PurchaseStockStatus {
  NOT_POSTED
  PARTIAL
  POSTED
  NO_STOCK
}

enum PurchaseType {
  STOCK_PRODUCTS
  OS_PARTS
  SUPPLIES
  TOOLS
  THIRD_PARTY_SERVICE
  OPERATIONAL_EXPENSE
  OTHER
}

enum SupplierPersonType {
  PJ
  PF
}

enum SupplierType {
  AUTOPECAS
  MOTOPECAS
  FERRAMENTAS
  LUBRIFICANTES
  PNEUS
  ELETRICA
  FUNILARIA
  TERCEIRIZADO
  OUTROS
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum FinancialEntryOrigin {
  MANUAL
  PURCHASE
  SERVICE_ORDER
  PAYROLL
  COMMISSION
  EXPENSE
  ADJUSTMENT
}

enum FinancialCategoryType {
  INCOME
  EXPENSE
}

enum FinancialEntryType {
  PAYABLE
  RECEIVABLE
}

enum FinancialEntryStatus {
  OPEN
  PAID
  CANCELLED
}

enum StockMovementType {
  IN
  OUT_OS
  RESERVE
  RELEASE
  ADJUST
  RETURN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  BOLETO
  TRANSFER
  OTHER
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  SUPPLY
  WITHDRAWAL
  PAYMENT_IN
  PAYMENT_OUT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum EmploymentType {
  CLT
  AUTONOMO
  MEI
  TERCEIRIZADO
  DIARISTA
  COMISSIONADO
  OUTRO
}

enum EmployeePaymentType {
  FIXO
  FIXO_MAIS_COMISSAO
  SOMENTE_COMISSAO
  DIARIA
  POR_SERVICO
  TERCEIRIZADO
}

enum PaymentPeriodicity {
  MENSAL
  QUINZENAL
  SEMANAL
}

enum CommissionRuleType {
  PERCENTUAL
  VALOR_FIXO
  META
  MANUAL
}

enum CommissionBase {
  MAO_DE_OBRA
  PECAS
  TOTAL_OS
  SERVICO_ESPECIFICO
  PRODUTO_ESPECIFICO
  VENDA_BALCAO
  OS_FINALIZADA
}

enum CommissionTrigger {
  ORCAMENTO_APROVADO
  SERVICO_FINALIZADO
  OS_FINALIZADA
  OS_ENTREGUE
  PAGAMENTO_RECEBIDO
}

enum GeneratedCommissionStatus {
  PENDENTE
  APROVADA
  PAGA
  CANCELADA
  ESTORNADA
}

enum CommissionItemType {
  SERVICO
  PECA
  OS
  MANUAL
}

enum EmployeeEntryType {
  VALE
  ADIANTAMENTO
  BONUS
  DESCONTO
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  DIARIA
  AJUDA_CUSTO
}

enum EmployeeEntryStatus {
  PENDENTE
  APLICADO
  CANCELADO
  PAGO
}

enum PayrollStatus {
  ABERTA
  FECHADA
  PAGA
  CANCELADA
}

enum PayrollItemType {
  SALARIO
  COMISSAO
  BONUS
  VALE
  ADIANTAMENTO
  DESCONTO
  AJUSTE
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  tradeName String?  @map("trade_name")
  document  String?  // CNPJ
  email             String?
  loginEmailDomain  String?  @map("login_email_domain")
  phone             String?
  plan      String   @default("professional")
  logoUrl           String?  @map("logo_url")
  primaryColor      String   @default("#0E7490") @map("primary_color")
  accentColor       String   @default("#0F3D4C") @map("accent_color")
  footerText        String?  @map("footer_text")
  termsServiceOrder String?  @map("terms_service_order") @db.Text
  termsQuote        String?  @map("terms_quote") @db.Text
  portalWelcome     String?  @map("portal_welcome")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches Branch[]
  members  OrganizationMember[]
  roles    Role[]
  customers Customer[]
  vehicles  Vehicle[]
  serviceOrders ServiceOrder[]
  quotes    Quote[]
  products      Product[]
  serviceOrderItems ServiceOrderItem[]
  statusHistory   ServiceOrderStatusHistory[]
  checklistItems  ServiceOrderChecklistItem[]
  attachments     Attachment[]
  quoteLines      QuoteLine[]
  quoteTokens     QuoteAccessToken[]
  customerContacts CustomerContact[]
  auditLogs     AuditLog[]
  dailyRevenues DailyRevenue[]
  suppliers Supplier[]
  purchaseOrders PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  financialEntries FinancialEntry[]
  financialCategories FinancialCategory[]
  paymentFeeConfigs PaymentFeeConfig[]
  paymentFeeRecords PaymentFeeRecord[]
  financialPaymentSplits FinancialPaymentSplit[]
  serviceCatalog ServiceCatalog[]
  stockMovements StockMovement[]
  appointments Appointment[]
  cashSessions CashRegisterSession[]
  cashMovements CashRegisterMovement[]
  portalAccessTokens PortalAccessToken[]
  pushSubscriptions PushSubscription[]
  portalNotifications PortalNotification[]
  fcmTokens FcmToken[]
  officeNotifications OfficeNotification[]
  jobTitles JobTitle[]
  employees Employee[]
  employeePaymentConfigs EmployeePaymentConfig[]
  commissionRules EmployeeCommissionRule[]
  generatedCommissions GeneratedCommission[]
  employeeEntries EmployeeEntry[]
  payrolls Payroll[]
  teamActionLogs TeamActionLog[]
  employeeSchedules EmployeeSchedule[]
  employeeScheduleRecurrences EmployeeScheduleRecurrence[]
  employeeScheduleHistories EmployeeScheduleHistory[]
  employeeTimeClockEntries EmployeeTimeClockEntry[]
  employeeTimeClockDays EmployeeTimeClockDay[]
  employeeRequests EmployeeRequest[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  code           String?
  address        String?
  street         String?
  addressNumber  String?  @map("address_number")
  complement     String?
  district       String?
  city           String?
  state          String?
  zipCode        String?  @map("zip_code")
  isMain         Boolean  @default(false) @map("is_main")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]
  serviceOrders ServiceOrder[]

  @@index([organizationId])
  @@map("branches")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile Profile?
  members OrganizationMember[]
  auditLogs AuditLog[]
  statusChanges ServiceOrderStatusHistory[]
  uploadedAttachments Attachment[]
  openedCashSessions CashRegisterSession[] @relation("CashOpenedBy")
  closedCashSessions CashRegisterSession[] @relation("CashClosedBy")
  purchasesCreated PurchaseOrder[] @relation("PurchaseCreatedBy")

  @@map("users")
}

model Profile {
  id        String   @id
  userId    String   @unique @map("user_id")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  roleId         String   @map("role_id")
  branchId       String?  @map("branch_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  consultantOrders ServiceOrder[] @relation("ConsultantOrders")
  mechanicOrders   ServiceOrder[] @relation("MechanicOrders")
  appointments     Appointment[]
  employee         Employee?

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  slug           String
  name           String
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]
  permissions  RolePermission[]

  @@unique([organizationId, slug])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  action         String
  resource       String?
  reason         String?
  metadata       Json?
  ipAddress      String?  @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  customerType   CustomerType @default(PF) @map("customer_type")
  name           String
  document       String?
  phone          String?
  whatsapp       String?
  email          String?
  notes          String?
  street         String?
  addressNumber  String?      @map("address_number")
  complement     String?
  district       String?
  city           String?
  state          String?
  zipCode        String?      @map("zip_code")
  origin         String?
  isActive       Boolean      @default(true) @map("is_active")
  isVip          Boolean      @default(false) @map("is_vip")
  isBlocked      Boolean      @default(false) @map("is_blocked")
  isDelinquent   Boolean      @default(false) @map("is_delinquent")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]
  contacts     CustomerContact[]
  financialEntries FinancialEntry[]
  portalNotifications PortalNotification[]

  @@index([organizationId])
  @@index([organizationId, name])
  @@map("customers")
}

model CustomerContact {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  customerId     String   @map("customer_id")
  name           String
  role           String?
  phone          String?
  email          String?
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_contacts")
}

model Vehicle {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  customerId     String       @map("customer_id")
  plate          String
  brand          String?
  model          String?
  year           Int?
  color          String?
  vehicleKind    VehicleKind  @default(CAR) @map("vehicle_kind")
  chassis        String?
  renavam        String?
  fuelType       String?      @map("fuel_type")
  currentKm      Int?         @map("current_km")
  notes          String?
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceOrders ServiceOrder[]
  appointments  Appointment[]
  portalAccessTokens PortalAccessToken[]
  pushSubscriptions PushSubscription[]
  portalNotifications PortalNotification[]
  fcmTokens FcmToken[]

  @@unique([organizationId, plate])
  @@index([organizationId])
  @@map("vehicles")
}

model ServiceOrder {
  id                   String               @id @default(cuid())
  organizationId       String               @map("organization_id")
  branchId             String?              @map("branch_id")
  vehicleId            String               @map("vehicle_id")
  consultantMemberId   String?              @map("consultant_member_id")
  mechanicMemberId     String?              @map("mechanic_member_id")
  generalResponsibleId String?              @map("general_responsible_id")
  checklistById        String?              @map("checklist_by_id")
  diagnosisById        String?              @map("diagnosis_by_id")
  quoteById            String?              @map("quote_by_id")
  executionById        String?              @map("execution_by_id")
  finalizedById        String?              @map("finalized_by_id")
  number               Int
  status               ServiceOrderStatus   @default(RECEIVED)
  priority             ServiceOrderPriority @default(NORMAL)
  serviceType          String?              @map("service_type")
  entryChannel         String?              @map("entry_channel")
  bay                  String?
  entryKm              Int?                 @map("entry_km")
  enteredAt            DateTime?            @map("entered_at")
  complaint            String?
  diagnosis            String?
  internalNotes        String?              @map("internal_notes")
  customerVisibleNotes String?              @map("customer_visible_notes")
  paymentAgreement     String?              @map("payment_agreement")
  estimatedAt          DateTime?            @map("estimated_at")
  totalAmount          Decimal              @default(0) @map("total_amount") @db.Decimal(12, 2)
  attachmentsPurgeAt   DateTime?            @map("attachments_purge_at")
  attachmentsPurgedAt  DateTime?            @map("attachments_purged_at")
  deletedAt            DateTime?            @map("deleted_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  consultant   OrganizationMember? @relation("ConsultantOrders", fields: [consultantMemberId], references: [id], onDelete: SetNull)
  mechanic     OrganizationMember? @relation("MechanicOrders", fields: [mechanicMemberId], references: [id], onDelete: SetNull)
  generalResponsible Employee? @relation("OsGeneralResponsible", fields: [generalResponsibleId], references: [id], onDelete: SetNull)
  checklistBy        Employee? @relation("OsChecklistBy", fields: [checklistById], references: [id], onDelete: SetNull)
  diagnosisBy        Employee? @relation("OsDiagnosisBy", fields: [diagnosisById], references: [id], onDelete: SetNull)
  quoteBy            Employee? @relation("OsQuoteBy", fields: [quoteById], references: [id], onDelete: SetNull)
  executionBy        Employee? @relation("OsExecutionBy", fields: [executionById], references: [id], onDelete: SetNull)
  finalizedBy        Employee? @relation("OsFinalizedBy", fields: [finalizedById], references: [id], onDelete: SetNull)
  quotes       Quote[]
  generatedCommissions GeneratedCommission[]
  items        ServiceOrderItem[]
  statusHistory ServiceOrderStatusHistory[]
  checklistItems ServiceOrderChecklistItem[]
  attachments  Attachment[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  appointment  Appointment?
  financialEntries FinancialEntry[]
  portalAccessTokens PortalAccessToken[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@map("service_orders")
}

model ServiceOrderStatusHistory {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  serviceOrderId String              @map("service_order_id")
  fromStatus     ServiceOrderStatus? @map("from_status")
  toStatus       ServiceOrderStatus  @map("to_status")
  userId         String?             @map("user_id")
  reason         String?
  notes          String?
  createdAt      DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceOrderId])
  @@map("service_order_status_history")
}

model ServiceOrderChecklistItem {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  serviceOrderId String           @map("service_order_id")
  category       String
  label          String
  sortOrder      Int              @default(0) @map("sort_order")
  result         ChecklistResult?
  notes          String?
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_checklist_items")
}

model Attachment {
  id                String               @id @default(cuid())
  organizationId    String               @map("organization_id")
  entityType        AttachmentEntityType @map("entity_type")
  entityId          String               @map("entity_id")
  serviceOrderId    String?              @map("service_order_id")
  category          String               @default("general")
  fileName          String               @map("file_name")
  mimeType          String               @map("mime_type")
  storagePath       String               @map("storage_path")
  visibleToCustomer Boolean              @default(false) @map("visible_to_customer")
  showOnQuote       Boolean              @default(false) @map("show_on_quote")
  uploadedByUserId String?             @map("uploaded_by_user_id")
  createdAt         DateTime             @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  uploadedBy   User?         @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId])
  @@index([serviceOrderId])
  @@map("attachments")
}

enum ServiceOrderItemType {
  SERVICE
  PART
}

model ServiceOrderItem {
  id             String               @id @default(cuid())
  organizationId String               @map("organization_id")
  serviceOrderId String               @map("service_order_id")
  productId      String?              @map("product_id")
  catalogItemId  String?              @map("catalog_item_id")
  description    String
  itemType       ServiceOrderItemType @default(SERVICE) @map("item_type")
  quantity           Int                  @default(1)
  unitPrice          Decimal              @default(0) @map("unit_price") @db.Decimal(12, 2)
  unitCost           Decimal?             @map("unit_cost") @db.Decimal(12, 2)
  discount           Decimal              @default(0) @db.Decimal(12, 2)
  executorId         String?              @map("executor_id")
  soldById           String?              @map("sold_by_id")
  appliedById        String?              @map("applied_by_id")
  separatedById      String?              @map("separated_by_id")
  expectedCommission Decimal?             @map("expected_commission") @db.Decimal(12, 2)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  catalogItem  ServiceCatalog? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  executor     Employee?    @relation("ItemExecutor", fields: [executorId], references: [id], onDelete: SetNull)
  soldBy       Employee?    @relation("ItemSoldBy", fields: [soldById], references: [id], onDelete: SetNull)
  appliedBy    Employee?    @relation("ItemAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)
  separatedBy  Employee?    @relation("ItemSeparatedBy", fields: [separatedById], references: [id], onDelete: SetNull)
  generatedCommissions GeneratedCommission[]

  @@index([serviceOrderId])
  @@index([executorId])
  @@map("service_order_items")
}

model Quote {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  serviceOrderId String      @map("service_order_id")
  number         Int?
  status         QuoteStatus @default(PENDING)
  amount         Decimal     @db.Decimal(12, 2)
  validUntil     DateTime?   @map("valid_until") @db.Date
  terms          String?
  paymentAgreement String?  @map("payment_agreement")
  customerComment String?    @map("customer_comment")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  lines        QuoteLine[]
  accessTokens QuoteAccessToken[]
  financialEntries FinancialEntry[]
  generatedCommissions GeneratedCommission[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@map("quotes")
}

model QuoteLine {
  id                String        @id @default(cuid())
  organizationId    String        @map("organization_id")
  quoteId           String        @map("quote_id")
  lineType          QuoteLineType @default(SERVICE) @map("line_type")
  description       String
  quantity          Int           @default(1)
  unitPrice         Decimal       @default(0) @map("unit_price") @db.Decimal(12, 2)
  discount          Decimal       @default(0) @db.Decimal(12, 2)
  approved          Boolean?
  sortOrder         Int           @default(0) @map("sort_order")
  serviceOrderItemId String?      @map("service_order_item_id")
  createdAt         DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_lines")
}

model QuoteAccessToken {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  quoteId        String   @map("quote_id")
  token          String   @unique
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
